{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ultimate Basic",
  "scopeName": "source.ub",
  "fileTypes": ["ub"],
  "patterns": [
    { "include": "#print-hash" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-c64" },
    { "include": "#compound-bitwise" },
    { "include": "#keywords-operators" },
    { "include": "#builtin-functions" },
    { "include": "#types" },
    { "include": "#labels" },
    { "include": "#inline-asm" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "print-hash": {
      "patterns": [
        {
          "name": "support.function.c64.serial.ub",
          "match": "(?i)\\bprint#"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.ub",
          "match": "(?<!\\w)#.*$"
        },
        {
          "name": "comment.line.rem.ub",
          "match": "(?i)\\brem\\b.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ub",
      "begin": "\"",
      "end": "\"",
      "patterns": []
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.ub",
          "match": "\\$[0-9A-Fa-f]+"
        },
        {
          "name": "constant.numeric.binary.ub",
          "match": "%[01]+"
        },
        {
          "name": "constant.numeric.decimal.ub",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.ub",
          "match": "(?i)\\b(if|then|else|end|for|to|step|next|while|loop|times|break|continue|goto|gosub|label|sub|fn|call|return|repeat|until|select|case|inc|dec|onerr)\\b"
        },
        {
          "name": "keyword.control.exit.ub",
          "match": "(?i)\\b(bye|exit)\\b"
        }
      ]
    },
    "keywords-declaration": {
      "patterns": [
        {
          "name": "keyword.other.declaration.ub",
          "match": "(?i)\\b(var|const)\\b"
        },
        {
          "name": "keyword.other.include.ub",
          "match": "(?i)\\b(include|incbin|charset)\\b"
        },
        {
          "name": "keyword.other.data.ub",
          "match": "(?i)\\b(data|read)\\b"
        }
      ]
    },
    "keywords-c64": {
      "patterns": [
        {
          "name": "support.function.c64.output.ub",
          "match": "(?i)\\b(print|cls|screen|lowercase|uppercase)\\b"
        },
        {
          "name": "support.function.c64.graphics.ub",
          "match": "(?i)\\b(graphics|gcls|plot|mplot|plot4|line|circle|circle4|display|cursor|paint|scroll)\\b"
        },
        {
          "name": "support.function.c64.color.ub",
          "match": "(?i)\\b(color)\\b"
        },
        {
          "name": "support.function.c64.memory.ub",
          "match": "(?i)\\b(poke|poke16|fill|memcopy|drawmem)\\b"
        },
        {
          "name": "support.function.c64.sprite.ub",
          "match": "(?i)\\b(sprite|sprdef|chardef|sprite_frame)\\b"
        },
        {
          "name": "support.function.c64.sound.ub",
          "match": "(?i)\\b(sound|sid|music)\\b"
        },
        {
          "name": "support.function.c64.timing.ub",
          "match": "(?i)\\b(wait|waitkey|delay|irq|irq_exit|nmi|nmi_exit|cia_timer)\\b"
        },
        {
          "name": "support.function.c64.u64.ub",
          "match": "(?i)\\b(speed|badlines)\\b"
        },
        {
          "name": "support.function.c64.reu.ub",
          "match": "(?i)\\b(reu)\\b"
        },
        {
          "name": "support.function.c64.assembly.ub",
          "match": "(?i)\\b(sys|asm)\\b"
        },
        {
          "name": "support.function.c64.string.ub",
          "match": "(?i)\\b(numstr|int_to_str)\\b"
        },
        {
          "name": "support.function.c64.disk.ub",
          "match": "(?i)\\b(load|save|open|close|input)\\b"
        },
        {
          "name": "constant.language.c64.modifier.ub",
          "match": "(?i)\\b(on|off|max|fast|multi|block|raster|text|border|bg|stash|fetch|swap|color|multicolor|erase|xor|expand|priority|at|volume|stop|play|pause|resume|screen|narrow|wide|left|row)\\b"
        }
      ]
    },
    "compound-bitwise": {
      "patterns": [
        {
          "name": "keyword.operator.compound.bitwise.ub",
          "match": "(?i)\\b(and|or|xor|shl|shr)="
        }
      ]
    },
    "keywords-operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.ub",
          "match": "(?i)\\b(and|or|xor|not|bnot|shl|shr|mod)\\b"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.io.ub",
          "match": "(?i)\\b(getch|inkey|joy)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.print.ub",
          "match": "(?i)\\b(spc|tab)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.memory.ub",
          "match": "(?i)\\b(peek|peek16)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.math.ub",
          "match": "(?i)\\b(abs|min|max|sgn|rnd|sin|cos|clamp)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.string.ub",
          "match": "(?i)\\b(chr\\$|str\\$|len|asc|hex|bin|str_to_int)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.sprite.ub",
          "match": "(?i)\\b(sprite_hit|sprite_bg_hit|sprite_x|sprite_y)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.mouse.ub",
          "match": "(?i)\\b(mouse_x|mouse_y|mouse_btn)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.reu.ub",
          "match": "(?i)\\b(reu_present|reudet)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.u64.ub",
          "match": "(?i)\\b(turbo)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.string2.ub",
          "match": "(?i)\\b(val|dec)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.float.ub",
          "match": "(?i)\\b(int)\\s*(?=\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.ub",
          "match": "(?i)\\b(int|word|float|string|array|array_word)\\b"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.ub",
          "match": "(?i)(?<=\\blabel\\s)\\s*([A-Za-z_][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.label.goto.ub",
          "match": "(?i)(?<=\\bgoto\\s)\\s*([A-Za-z_][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.label.gosub.ub",
          "match": "(?i)(?<=\\bgosub\\s)\\s*([A-Za-z_][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.function.ub",
          "match": "(?i)(?<=\\bsub\\s)\\s*([A-Za-z_][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.function.fn.ub",
          "match": "(?i)(?<=\\bfn\\s)\\s*([A-Za-z_][A-Za-z0-9_]*)"
        }
      ]
    },
    "inline-asm": {
      "name": "meta.embedded.asm.ub",
      "begin": "(?i)\\basm\\s*\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "keyword.other.asm.ub" }
      },
      "endCaptures": {
        "0": { "name": "keyword.other.asm.ub" }
      },
      "patterns": [
        { "include": "#asm-comment" },
        { "include": "#asm-label" },
        { "include": "#asm-mnemonic" },
        { "include": "#asm-register" },
        { "include": "#numbers" }
      ]
    },
    "asm-comment": {
      "patterns": [
        {
          "name": "comment.line.asm.ub",
          "match": "(;|//).*$"
        }
      ]
    },
    "asm-label": {
      "patterns": [
        {
          "name": "entity.name.label.asm.ub",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*:"
        },
        {
          "name": "entity.name.label.asm-ref.ub",
          "match": "#[<>][A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "asm-mnemonic": {
      "patterns": [
        {
          "name": "keyword.control.asm.branch.ub",
          "match": "(?i)\\b(BCC|BCS|BEQ|BMI|BNE|BPL|BVC|BVS)\\b"
        },
        {
          "name": "keyword.control.asm.jump.ub",
          "match": "(?i)\\b(JMP|JSR|RTS|RTI|BRK)\\b"
        },
        {
          "name": "support.function.asm.load-store.ub",
          "match": "(?i)\\b(LDA|LDX|LDY|STA|STX|STY)\\b"
        },
        {
          "name": "support.function.asm.transfer.ub",
          "match": "(?i)\\b(TAX|TAY|TXA|TYA|TSX|TXS)\\b"
        },
        {
          "name": "support.function.asm.stack.ub",
          "match": "(?i)\\b(PHA|PLA|PHP|PLP)\\b"
        },
        {
          "name": "support.function.asm.arithmetic.ub",
          "match": "(?i)\\b(ADC|SBC|INC|INX|INY|DEC|DEX|DEY)\\b"
        },
        {
          "name": "support.function.asm.logic.ub",
          "match": "(?i)\\b(AND|ORA|EOR|BIT)\\b"
        },
        {
          "name": "support.function.asm.shift.ub",
          "match": "(?i)\\b(ASL|LSR|ROL|ROR)\\b"
        },
        {
          "name": "support.function.asm.flag.ub",
          "match": "(?i)\\b(CLC|SEC|CLD|SED|CLI|SEI|CLV|NOP)\\b"
        },
        {
          "name": "support.function.asm.compare.ub",
          "match": "(?i)\\b(CMP|CPX|CPY)\\b"
        }
      ]
    },
    "asm-register": {
      "patterns": [
        {
          "name": "variable.language.asm.register.ub",
          "match": "(?i)(?<=[,\\s])\\b(A|X|Y)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.ub",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.compound.ub",
          "match": "\\+=|-=|\\*=|/="
        },
        {
          "name": "keyword.operator.assignment.ub",
          "match": "="
        },
        {
          "name": "punctuation.separator.statement.ub",
          "match": ":"
        },
        {
          "name": "keyword.operator.arithmetic.ub",
          "match": "[+\\-*/]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.ub",
          "match": "[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    }
  }
}
